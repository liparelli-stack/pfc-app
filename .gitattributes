cd /home/fl/projetos/crmappy-v0101

# Remover o .gitattributes corrompido
rm .gitattributes

# Criar um .gitattributes correto para projeto web
cat > .gitattributes << 'EOF'
# Auto detect text files and perform LF normalization
* text=auto

# JavaScript/TypeScript
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf

# Styles
*.css text eol=lf

# Config
*.json text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.env text eol=lf

# Binaries
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
